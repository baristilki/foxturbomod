<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- CYBER TEMA — neon mavi, futurik -->
    <Color x:Key="AccentColor">#00D9FF</Color>
    <Color x:Key="AccentColorDim">#0088AA</Color>
    <Color x:Key="AccentColorGlow">#66E8FF</Color>

    <SolidColorBrush x:Key="AccentBrush" Color="#00D9FF" />
    <SolidColorBrush x:Key="AccentBrushDim" Color="#0088AA" />
    <SolidColorBrush x:Key="AccentBrushGlow" Color="#66E8FF" />

    <SolidColorBrush x:Key="PanelBrush" Color="#101822" />
    <SolidColorBrush x:Key="PanelBrushDim" Color="#0C1218" />
    <SolidColorBrush x:Key="PanelBrushBright" Color="#16202C" />

    <SolidColorBrush x:Key="WindowBackground" Color="#070B11" />
    <SolidColorBrush x:Key="BorderBrushDim" Color="#1F2A38" />
    <SolidColorBrush x:Key="TextPrimary" Color="#E8F4FF" />
    <SolidColorBrush x:Key="TextSecondary" Color="#7090A8" />

    <SolidColorBrush x:Key="HighlightPanelBg" Color="#0A1A22" />
    <SolidColorBrush x:Key="HighlightPanelChip" Color="#0E2330" />

</ResourceDictionary>
