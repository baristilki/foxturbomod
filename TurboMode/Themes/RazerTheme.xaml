<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- RAZER TEMA — neon yeşil, klasik gaming -->
    <Color x:Key="AccentColor">#44D62C</Color>
    <Color x:Key="AccentColorDim">#2B8C1A</Color>
    <Color x:Key="AccentColorGlow">#7FEA66</Color>

    <SolidColorBrush x:Key="AccentBrush" Color="#44D62C" />
    <SolidColorBrush x:Key="AccentBrushDim" Color="#2B8C1A" />
    <SolidColorBrush x:Key="AccentBrushGlow" Color="#7FEA66" />

    <SolidColorBrush x:Key="PanelBrush" Color="#141A14" />
    <SolidColorBrush x:Key="PanelBrushDim" Color="#0F140F" />
    <SolidColorBrush x:Key="PanelBrushBright" Color="#1E251E" />

    <SolidColorBrush x:Key="WindowBackground" Color="#0A0E0A" />
    <SolidColorBrush x:Key="BorderBrushDim" Color="#2A332A" />
    <SolidColorBrush x:Key="TextPrimary" Color="#F0FFF0" />
    <SolidColorBrush x:Key="TextSecondary" Color="#80A080" />

    <SolidColorBrush x:Key="HighlightPanelBg" Color="#0E1A0E" />
    <SolidColorBrush x:Key="HighlightPanelChip" Color="#142214" />

</ResourceDictionary>
