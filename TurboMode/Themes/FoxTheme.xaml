<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- FOX TEMA — turuncu, sıcak, default -->
    <Color x:Key="AccentColor">#FF7A29</Color>
    <Color x:Key="AccentColorDim">#A04A1A</Color>
    <Color x:Key="AccentColorGlow">#FFAA55</Color>

    <SolidColorBrush x:Key="AccentBrush" Color="#FF7A29" />
    <SolidColorBrush x:Key="AccentBrushDim" Color="#A04A1A" />
    <SolidColorBrush x:Key="AccentBrushGlow" Color="#FFAA55" />

    <SolidColorBrush x:Key="PanelBrush" Color="#1A1A20" />
    <SolidColorBrush x:Key="PanelBrushDim" Color="#15151B" />
    <SolidColorBrush x:Key="PanelBrushBright" Color="#22222A" />

    <SolidColorBrush x:Key="WindowBackground" Color="#0E0E13" />
    <SolidColorBrush x:Key="BorderBrushDim" Color="#2A2A33" />
    <SolidColorBrush x:Key="TextPrimary" Color="#F0F0F0" />
    <SolidColorBrush x:Key="TextSecondary" Color="#909098" />

    <!-- Vurgu paneli (sonuç) -->
    <SolidColorBrush x:Key="HighlightPanelBg" Color="#1A1410" />
    <SolidColorBrush x:Key="HighlightPanelChip" Color="#2A1F14" />

</ResourceDictionary>
