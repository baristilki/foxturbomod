<Window x:Class="TurboMode.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:vm="clr-namespace:TurboMode.ViewModels"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Fox Turbo Mod" Height="940" Width="560"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="#0E0E13"
        Icon="/Resources/FoxMod.ico">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="22,14,22,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Başlık -->
            <RowDefinition Height="Auto" />   <!-- Buton bar -->
            <RowDefinition Height="Auto" />   <!-- Hakkında -->
            <RowDefinition Height="Auto" />   <!-- Toggle paneli -->
            <RowDefinition Height="Auto" />   <!-- Sonuç -->
            <RowDefinition Height="Auto" />   <!-- FPS -->
            <RowDefinition Height="Auto" />   <!-- Aktif oyun + Haftalık özet -->
            <RowDefinition Height="Auto" />   <!-- Metrikler -->
            <RowDefinition Height="*" />      <!-- Oyun listesi -->
            <RowDefinition Height="Auto" />   <!-- Discord buton -->
            <RowDefinition Height="Auto" />   <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Başlık (sadece logo + isim, butonlar ayrı satır) -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <Image Source="/Resources/FoxLogo.png" Width="40" Height="40" Margin="0,0,12,0" />
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="FOX TURBO MOD" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}" />
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding VersionLabel}" FontSize="11"
                               Foreground="{StaticResource TextSecondary}" />
                    <TextBlock Text="{Binding UpdateBanner}" FontSize="11"
                               Foreground="{StaticResource AccentBrush}" Margin="8,0,0,0"
                               Cursor="Hand" MouseLeftButtonUp="OpenUpdate_Click" />
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <!-- Buton bar (alt satır) -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,0,0,12">
            <Button Content="📊 Geçmiş" Cursor="Hand" Click="History_Click"
                    Background="Transparent" BorderBrush="{StaticResource BorderBrushDim}"
                    Foreground="{StaticResource TextPrimary}" Padding="12,5" Margin="0,0,6,0" />
            <Button Content="🛡 Beyaz Liste" Cursor="Hand" Click="Whitelist_Click"
                    Background="Transparent" BorderBrush="{StaticResource BorderBrushDim}"
                    Foreground="{StaticResource TextPrimary}" Padding="12,5" Margin="0,0,6,0" />
            <Button Content="ℹ Hakkında" Cursor="Hand"
                    Command="{Binding ToggleAboutCommand}"
                    Background="Transparent" BorderBrush="{StaticResource BorderBrushDim}"
                    Foreground="{StaticResource TextSecondary}" Padding="12,5" />
        </StackPanel>

        <!-- Hakkında paneli -->
        <Border Grid.Row="2" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
                CornerRadius="10" Padding="18,14" Margin="0,0,0,12"
                Visibility="{Binding AboutOpen, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="Fox Turbo Mod nedir?" FontWeight="SemiBold" FontSize="14"
                           Foreground="{StaticResource AccentBrush}" Margin="0,0,0,6" />
                <TextBlock Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap" FontSize="12" LineHeight="18">
                    Oyun oynarken arka planda CPU/RAM tüketen uygulamaları
                    (OneDrive, Spotify, Chrome sekmeleri vb.) ve gereksiz Windows servislerini
                    geçici olarak <Run FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}">askıya alır</Run>
                    (kill etmez). Cache temizler, güç planını yüksek performansa geçirir, Game DVR'ı kapatır,
                    CPU önceliğini yükseltir. Oyun kapanınca her şeyi otomatik geri açar.
                </TextBlock>
                <TextBlock Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap"
                           FontSize="12" LineHeight="18" Margin="0,8,0,0">
                    <Run FontWeight="SemiBold">Yaptıkları:</Run>
                    arka plan dondurma • servisleri durdurma • cache temizleme • güç planı •
                    Game DVR off • CPU priority • görsel efekt minimize • CPU parking off
                </TextBlock>
                <TextBlock Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"
                           FontSize="12" LineHeight="18" Margin="0,6,0,0">
                    <Run FontWeight="SemiBold">Yapmadıkları:</Run>
                    cheat değildir • donanım performansı yükseltmez • PC'ye kalıcı zarar vermez •
                    Discord/OBS/antivirüse dokunmaz
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Ana toggle paneli -->
        <Border Grid.Row="3" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrushDim}" BorderThickness="1"
                CornerRadius="10" Padding="20,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusTitle}" FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}" />
                    <TextBlock Text="{Binding StatusDetail}" FontSize="12"
                               Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>

                <ToggleButton Grid.Column="1" Width="72" Height="38"
                              IsChecked="{Binding TurboEnabled, Mode=TwoWay}"
                              VerticalAlignment="Center" Cursor="Hand">
                    <ToggleButton.Style>
                        <Style TargetType="ToggleButton">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Pill" Background="#2A2A33"
                                                CornerRadius="19" BorderThickness="0">
                                            <Ellipse x:Name="Knob" Width="30" Height="30" Fill="White"
                                                     HorizontalAlignment="Left" Margin="4,0,0,0" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Pill" Property="Background"
                                                        Value="{StaticResource AccentBrush}" />
                                                <Setter TargetName="Knob" Property="HorizontalAlignment" Value="Right" />
                                                <Setter TargetName="Knob" Property="Margin" Value="0,0,4,0" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ToggleButton.Style>
                </ToggleButton>
            </Grid>
        </Border>

        <!-- SONUÇ paneli -->
        <Border Grid.Row="4" Margin="0,12,0,0" Background="#1A1410"
                BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
                CornerRadius="10" Padding="16,12"
                Visibility="{Binding ResultPanelVisibility}">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="🧊 Donduruldu" FontSize="11"
                                   Foreground="{StaticResource TextSecondary}" />
                        <TextBlock Text="{Binding ResultSuspendedText}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}" Margin="0,2,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="💾 RAM Kazancı" FontSize="11"
                                   Foreground="{StaticResource TextSecondary}" />
                        <TextBlock Text="{Binding ResultRamFreedText}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}" Margin="0,2,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="⚡ CPU" FontSize="11"
                                   Foreground="{StaticResource TextSecondary}" />
                        <TextBlock Text="{Binding ResultCpuDeltaText}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}" Margin="0,2,0,0" />
                    </StackPanel>
                </Grid>
                <TextBlock Text="{Binding ResultExtrasText}" FontSize="10"
                           Foreground="{StaticResource TextSecondary}" Margin="0,8,0,0"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- FPS paneli -->
        <Border Grid.Row="5" Margin="0,12,0,0" Background="#0F1A14"
                BorderBrush="#1E4F2E" BorderThickness="1"
                CornerRadius="10" Padding="16,12"
                Visibility="{Binding FpsPanelVisibility}">
            <StackPanel>
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="🎯 FPS Ölçümü (PresentMon)"
                               FontWeight="SemiBold" Foreground="#7FD49F" FontSize="13" />
                    <TextBlock Grid.Column="1" Text="{Binding FpsLiveText}"
                               FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" />
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Baseline" FontSize="10" Foreground="{StaticResource TextSecondary}" />
                        <TextBlock Text="{Binding FpsBaselineText}" FontSize="13"
                                   Foreground="{StaticResource TextPrimary}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Aktif" FontSize="10" Foreground="{StaticResource TextSecondary}" />
                        <TextBlock Text="{Binding FpsActiveText}" FontSize="13"
                                   Foreground="{StaticResource TextPrimary}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Fark" FontSize="10" Foreground="{StaticResource TextSecondary}" />
                        <TextBlock Text="{Binding FpsDeltaText}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{Binding FpsDeltaColor}" />
                    </StackPanel>
                </Grid>
                <TextBlock Text="⚠ Valorant/Vanguard çalışırken bu pencereyi kapatabilirsiniz."
                           FontSize="10" Foreground="#AA8866" TextWrapping="Wrap" Margin="0,8,0,0" />
            </StackPanel>
        </Border>

        <!-- Aktif oyun göstergesi + Haftalık özet -->
        <Grid Grid.Row="6" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource PanelBrushDim}"
                    BorderBrush="{StaticResource BorderBrushDim}" BorderThickness="1"
                    CornerRadius="8" Padding="14,10">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="10" Height="10" Fill="{Binding GameStatusColor}"
                             VerticalAlignment="Center" Margin="0,0,10,0" />
                    <TextBlock Text="{Binding GameStatus}" Foreground="{StaticResource TextPrimary}"
                               VerticalAlignment="Center" FontSize="12" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="{StaticResource PanelBrushDim}"
                    BorderBrush="{StaticResource BorderBrushDim}" BorderThickness="1"
                    CornerRadius="8" Padding="14,8" Cursor="Hand" MouseLeftButtonUp="History_Click">
                <StackPanel>
                    <TextBlock Text="{Binding WeeklySummaryText}" Foreground="{StaticResource TextPrimary}"
                               FontSize="12" FontWeight="SemiBold" />
                    <TextBlock Text="Bu hafta — Detay için tıkla" FontSize="10"
                               Foreground="{StaticResource TextSecondary}" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Canlı metrikler -->
        <Grid Grid.Row="7" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource PanelBrushDim}"
                    BorderBrush="{StaticResource BorderBrushDim}" BorderThickness="1"
                    CornerRadius="8" Padding="14,10">
                <StackPanel>
                    <TextBlock Text="CPU" FontSize="11" Foreground="{StaticResource TextSecondary}" />
                    <TextBlock Text="{Binding CpuLabel}" FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}" Margin="0,2,0,4" />
                    <ProgressBar Value="{Binding CpuPercent}" Maximum="100" Height="4"
                                 Foreground="{StaticResource AccentBrush}" Background="#2A2A33" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="{StaticResource PanelBrushDim}"
                    BorderBrush="{StaticResource BorderBrushDim}" BorderThickness="1"
                    CornerRadius="8" Padding="14,10">
                <StackPanel>
                    <TextBlock Text="RAM" FontSize="11" Foreground="{StaticResource TextSecondary}" />
                    <TextBlock Text="{Binding RamLabel}" FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}" Margin="0,2,0,4" />
                    <ProgressBar Value="{Binding RamPercent}" Maximum="100" Height="4"
                                 Foreground="{StaticResource AccentBrush}" Background="#2A2A33" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Yüklü oyunlar — yenilenmiş tasarım -->
        <Border Grid.Row="8" Margin="0,16,0,0" Background="{StaticResource PanelBrushDim}"
                BorderBrush="{StaticResource BorderBrushDim}" BorderThickness="1"
                CornerRadius="10" Padding="8">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Margin="8,4,8,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="🎮 Yüklü Oyunlar"
                               Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="13" />
                    <TextBlock Grid.Column="1" Text="{Binding LibraryStatusText}"
                               Foreground="{StaticResource TextSecondary}" FontSize="11"
                               VerticalAlignment="Center" />
                </Grid>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding InstalledGames}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="110" Height="130" Margin="5" CornerRadius="10"
                                        Background="#16161D" BorderThickness="0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#22222E" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="0" Opacity="0.4" />
                                    </Border.Effect>
                                    <Border.ToolTip>
                                        <TextBlock>
                                            <Run Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                            <LineBreak />
                                            <Run Text="{Binding Platform}" Foreground="#AAA" />
                                            <LineBreak />
                                            <Run Text="{Binding ExecutablePath}" FontSize="10" Foreground="#888" />
                                        </TextBlock>
                                    </Border.ToolTip>
                                    <Grid>
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <Border Width="56" Height="56" CornerRadius="10"
                                                    Background="#202028" Margin="0,8,0,6">
                                                <Image Source="{Binding Icon}" Width="44" Height="44"
                                                       Stretch="Uniform" />
                                            </Border>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       FontSize="10" TextAlignment="Center"
                                                       TextWrapping="Wrap" MaxWidth="100"
                                                       TextTrimming="CharacterEllipsis" MaxHeight="30" />
                                            <TextBlock Text="{Binding Platform}"
                                                       Foreground="#FF7A29"
                                                       FontSize="9" TextAlignment="Center" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Discord + GitHub destek butonları -->
        <Grid Grid.Row="9" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#252A4D"
                    BorderBrush="#5865F2" BorderThickness="1" CornerRadius="10"
                    Cursor="Hand" MouseLeftButtonUp="Discord_Click">
                <Grid Margin="14,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="💬" FontSize="20" VerticalAlignment="Center"
                               Margin="0,0,10,0" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Discord Destek" Foreground="White"
                                   FontWeight="SemiBold" FontSize="12" />
                        <TextBlock Text="peacefox — adı kopyalanır"
                                   Foreground="#B8BCDB" FontSize="10" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="#1A1A20"
                    BorderBrush="#444" BorderThickness="1" CornerRadius="10"
                    Cursor="Hand" MouseLeftButtonUp="GitHub_Click">
                <Grid Margin="14,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="⭐" FontSize="20" VerticalAlignment="Center"
                               Margin="0,0,10,0" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="GitHub" Foreground="White"
                                   FontWeight="SemiBold" FontSize="12" />
                        <TextBlock Text="baristilki/foxturbomod"
                                   Foreground="#999" FontSize="10" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Sistem durumu + footer -->
        <StackPanel Grid.Row="10" HorizontalAlignment="Center" Margin="0,10,0,0">
            <TextBlock Text="{Binding SystemStateLabel}" FontSize="10"
                       Foreground="{Binding SystemStateColor}" HorizontalAlignment="Center" />
            <TextBlock Text="{Binding FooterText}" FontSize="11"
                       Foreground="{StaticResource TextSecondary}"
                       HorizontalAlignment="Center" Margin="0,4,0,0" />
        </StackPanel>
    </Grid>
</Window>
