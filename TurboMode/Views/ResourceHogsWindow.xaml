<Window x:Class="TurboMode.Views.ResourceHogsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Kaynak Tüketenler" Height="540" Width="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackground}"
        Icon="/Resources/FoxMod.ico">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="💥 En Çok RAM Kullanan İşlemler"
                   FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimary}" />
        <TextBlock Grid.Row="1" Margin="0,4,0,16" TextWrapping="Wrap"
                   Foreground="{DynamicResource TextSecondary}" FontSize="11">
            Top 10 işlem, RAM kullanımına göre sıralı. 3 saniyede bir güncellenir.
            <Run FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}">🛡 Korunan</Run> = beyaz listede, Turbo açıkken bile dokunulmaz.
            <Run FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}">🎯 Hedef</Run> = Turbo açıkken askıya alınacak (askı listesinde varsa).
        </TextBlock>

        <Border Grid.Row="2" Background="{DynamicResource PanelBrushDim}"
                BorderBrush="{DynamicResource BorderBrushDim}" BorderThickness="1"
                CornerRadius="10" Padding="6">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="HogsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="14,10" Margin="4,2" CornerRadius="8"
                                    Background="{DynamicResource PanelBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   FontWeight="SemiBold" FontSize="13" />
                                        <TextBlock Foreground="{DynamicResource TextSecondary}" FontSize="10">
                                            <Run Text="PID:" /><Run Text="{Binding Pid}" />
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding Badge}" FontSize="10"
                                               Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,12,0" />
                                    <TextBlock Grid.Column="2" Text="{Binding DisplayRam}"
                                               Foreground="{DynamicResource AccentBrush}"
                                               FontSize="16" FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
