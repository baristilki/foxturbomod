<Window x:Class="TurboMode.Views.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Hoş geldin!" Height="640" Width="720"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{DynamicResource WindowBackground}"
        Icon="/Resources/FoxMod.ico">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <!-- Sayfa 1: Hoşgeldin -->
            <StackPanel x:Name="Page1" VerticalAlignment="Center">
                <Image Source="/Resources/FoxLogo.png" Width="120" Height="120"
                       HorizontalAlignment="Center" Margin="0,0,0,16" />
                <TextBlock Text="🦊 Fox Turbo Mod'a Hoş Geldin!"
                           FontSize="22" FontWeight="Bold" TextAlignment="Center"
                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,12" />
                <TextBlock Text="Windows için açık kaynak oyun performans yöneticisi."
                           FontSize="13" TextAlignment="Center"
                           Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,18" />
                <TextBlock TextWrapping="Wrap" TextAlignment="Center" FontSize="12" LineHeight="20"
                           Foreground="{DynamicResource TextPrimary}" MaxWidth="540">
                    Bir oyun açtığında arka planda CPU/RAM tüketen 30+ uygulamayı
                    geçici olarak askıya alır, gereksiz Windows servislerini durdurur,
                    Game DVR'ı kapatır, MMCSS gaming priority'yi açar ve cache'i temizler.
                    <LineBreak /><LineBreak />
                    <Run FontWeight="SemiBold">Oyun kapanınca her şey otomatik geri alınır.</Run>
                </TextBlock>
            </StackPanel>

            <!-- Sayfa 2: Ne yapar / ne yapmaz -->
            <StackPanel x:Name="Page2" VerticalAlignment="Center" Visibility="Collapsed">
                <TextBlock Text="🎯 Ne Yapar / Ne Yapmaz"
                           FontSize="22" FontWeight="Bold" TextAlignment="Center"
                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,18" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource ModernCard}" Padding="16">
                        <StackPanel>
                            <TextBlock Text="✅ YAPAR" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,8" />
                            <TextBlock TextWrapping="Wrap" FontSize="11" LineHeight="18"
                                       Foreground="{DynamicResource TextPrimary}">
                                • Arka plan süreçlerini askıya alır<LineBreak />
                                • Cache temizler (1-3 GB RAM)<LineBreak />
                                • Güç planını "High"a alır<LineBreak />
                                • CPU core parking kapatır<LineBreak />
                                • Game DVR kapatır<LineBreak />
                                • Oyun process'ine yüksek öncelik<LineBreak />
                                • Mouse acceleration off<LineBreak />
                                • Discord erişim sorununa çözüm
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource ModernCard}" Padding="16">
                        <StackPanel>
                            <TextBlock Text="❌ YAPMAZ" FontWeight="Bold"
                                       Foreground="#CC4444" Margin="0,0,0,8" />
                            <TextBlock TextWrapping="Wrap" FontSize="11" LineHeight="18"
                                       Foreground="{DynamicResource TextPrimary}">
                                • Cheat değildir<LineBreak />
                                • Donanım kimliğine dokunmaz<LineBreak />
                                • Anti-cheat sürücüyle uğraşmaz<LineBreak />
                                • Discord/OBS/antivirüse dokunmaz<LineBreak />
                                • Sistem-kritik servisleri durdurmaz<LineBreak />
                                • PC'ye kalıcı zarar vermez<LineBreak />
                                • İnternette gönderilmeyen bilgi
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>

            <!-- Sayfa 3: DİNAMİK öneri kartları -->
            <StackPanel x:Name="Page3" VerticalAlignment="Top" Visibility="Collapsed" Margin="0,10,0,0">
                <TextBlock Text="🎯 Şimdi Açman Gerekenler"
                           FontSize="22" FontWeight="Bold" TextAlignment="Center"
                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8" />
                <TextBlock TextWrapping="Wrap" TextAlignment="Center" FontSize="11"
                           Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,16" MaxWidth="500">
                    Sistemini analiz ettim. Aşağıdaki <Run FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}">4 en kritik</Run>
                    aksiyon FPS'ini ve oyun deneyimini hemen iyileştirir. Her birinin yanındaki butonla aç.
                </TextBlock>
                <ScrollViewer MaxHeight="380" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ActionList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ModernCard}" Padding="14,12" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Item.Icon}" FontSize="22"
                                                   VerticalAlignment="Top" Margin="0,2,12,0" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Item.Title}" FontWeight="SemiBold" FontSize="12"
                                                       Foreground="{DynamicResource TextPrimary}" />
                                            <TextBlock Text="{Binding Item.Description}" FontSize="10"
                                                       TextWrapping="Wrap" Margin="0,4,0,0"
                                                       Foreground="{DynamicResource TextSecondary}" LineHeight="15" />
                                        </StackPanel>
                                        <Border Grid.Column="2" Padding="8,3" CornerRadius="4"
                                                Background="{Binding BadgeBrush}"
                                                VerticalAlignment="Top" Margin="8,2,8,0">
                                            <TextBlock Text="{Binding Item.Badge}" Foreground="White" FontSize="10" />
                                        </Border>
                                        <Button Grid.Column="3" Content="Şimdi Aç" Tag="{Binding Item.Action}"
                                                Click="Action_Click" VerticalAlignment="Top"
                                                Style="{StaticResource ModernButton}"
                                                Background="{DynamicResource AccentBrush}" Foreground="White"
                                                Padding="12,5" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center"
                    Margin="0,16,0,16">
            <Ellipse x:Name="Dot1" Width="10" Height="10" Margin="4"
                     Fill="{DynamicResource AccentBrush}" />
            <Ellipse x:Name="Dot2" Width="10" Height="10" Margin="4"
                     Fill="{DynamicResource BorderBrushDim}" />
            <Ellipse x:Name="Dot3" Width="10" Height="10" Margin="4"
                     Fill="{DynamicResource BorderBrushDim}" />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" x:Name="SkipButton" Content="Atla" HorizontalAlignment="Left"
                    Style="{StaticResource ModernButton}" Padding="14,7" Click="Skip_Click" />
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="PrevButton" Content="◀ Önceki" Margin="0,0,8,0"
                        Style="{StaticResource ModernButton}" Padding="14,7"
                        Click="Prev_Click" IsEnabled="False" />
                <Button x:Name="NextButton" Content="Sonraki ▶"
                        Style="{StaticResource ModernButton}"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="White" Padding="20,7" Click="Next_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
