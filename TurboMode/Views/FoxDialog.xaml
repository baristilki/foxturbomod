<Window x:Class="TurboMode.Views.FoxDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Fox Turbo Mod" SizeToContent="Height" Width="460"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource WindowBackground}"
        Icon="/Resources/FoxMod.ico">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
            <TextBlock x:Name="IconLabel" Text="ℹ" FontSize="28" Margin="0,0,12,0"
                       VerticalAlignment="Center" Foreground="{DynamicResource AccentBrush}" />
            <TextBlock x:Name="TitleLabel" Text="Title"
                       FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap" MaxWidth="380" />
        </StackPanel>

        <TextBlock Grid.Row="1" x:Name="MessageLabel" Text="Message"
                   Foreground="{DynamicResource TextPrimary}" FontSize="12"
                   LineHeight="18" TextWrapping="Wrap" Margin="0,0,0,18" />

        <StackPanel Grid.Row="2" x:Name="ButtonPanel" Orientation="Horizontal"
                    HorizontalAlignment="Right" />
    </Grid>
</Window>
