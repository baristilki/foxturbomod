<Window x:Class="TurboMode.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Ayarlar" Height="720" Width="860"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackground}"
        Icon="/Resources/FoxMod.ico">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sol menü -->
        <Border Grid.Column="0" Background="{DynamicResource PanelBrushDim}"
                BorderBrush="{DynamicResource BorderBrushDim}" BorderThickness="1"
                CornerRadius="10" Padding="8">
            <ListBox x:Name="CategoryList" Background="Transparent" BorderThickness="0"
                     SelectionChanged="Category_Changed">
                <ListBoxItem Content="⚡ Optimizasyonlar" IsSelected="True" Tag="opt" Padding="10,8" />
                <ListBoxItem Content="🌐 Ağ &amp; DPI" Tag="net" Padding="10,8" />
                <ListBoxItem Content="🎯 Tespit &amp; FPS" Tag="fps" Padding="10,8" />
                <ListBoxItem Content="🎨 Görünüm &amp; Tema" Tag="theme" Padding="10,8" />
                <ListBoxItem Content="📺 Overlay" Tag="overlay" Padding="10,8" />
                <ListBoxItem Content="⌨ Hotkeys" Tag="hotkey" Padding="10,8" />
                <ListBoxItem Content="🔧 Gelişmiş" Tag="advanced" Padding="10,8" />
            </ListBox>
        </Border>

        <!-- Sağ içerik -->
        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- OPTIMIZASYONLAR -->
                <StackPanel x:Name="OptPanel">
                    <TextBlock Text="⚡ Performans Optimizasyonları" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4" />
                    <TextBlock Text="Turbo açıldığında otomatik uygulanacak. Hepsi geri alınabilir."
                               Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="0,0,0,16" />

                    <CheckBox x:Name="CbMemory" Content="Standby memory cache temizleme (1-3 GB serbest RAM)"
                              Style="{StaticResource ToggleSwitchStyle}" Margin="0,6" />
                    <CheckBox x:Name="CbPower" Content="Yüksek Performans güç planı"
                              Style="{StaticResource ToggleSwitchStyle}" Margin="0,6" />
                    <CheckBox x:Name="CbGameDvr" Content="Game DVR / Xbox Game Bar otomatik kapat"
                              Style="{StaticResource ToggleSwitchStyle}" Margin="0,6" />
                    <CheckBox x:Name="CbPriority" Content="Oyun sürecine yüksek öncelik"
                              Style="{StaticResource ToggleSwitchStyle}" Margin="0,6" />
                    <CheckBox x:Name="CbVisual" Content="Görsel efektleri minimize (pencere animasyonları off)"
                              Style="{StaticResource ToggleSwitchStyle}" Margin="0,6" />
                    <CheckBox x:Name="CbCpuParking" Content="CPU core parking off (tüm çekirdekler aktif)"
                              Style="{StaticResource ToggleSwitchStyle}" Margin="0,6" />
                    <CheckBox x:Name="CbMmcss" Content="MMCSS gaming priority (multimedia thread öncelik)"
                              Style="{StaticResource ToggleSwitchStyle}" Margin="0,6" />
                    <CheckBox x:Name="CbMouse" Content="Mouse acceleration off (1:1 hareket — competitive standart)"
                              Style="{StaticResource ToggleSwitchStyle}" Margin="0,6" />
                </StackPanel>

                <!-- AĞ & DPI -->
                <StackPanel x:Name="NetPanel" Visibility="Collapsed">
                    <TextBlock Text="🌐 Ağ &amp; DPI" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4" />
                    <TextBlock TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="0,0,0,16">
                        Ağ ayarları varsayılan KAPALI — bazı oyunlarda (CoD/BF) latency artırabilir. Sadece sorun yaşıyorsan aç.
                    </TextBlock>

                    <CheckBox x:Name="CbNetwork" Content="Network QoS politikası (DSCP=46 oyun sürecine)"
                              Style="{StaticResource ToggleSwitchStyle}" Margin="0,6" />

                    <TextBlock Text="DNS &amp; DPI Bypass için: ana ekrandan 🚀 Öneriler → DNS / GoodbyeDPI butonlarını kullan."
                               Foreground="{DynamicResource TextSecondary}" FontSize="10"
                               TextWrapping="Wrap" Margin="0,12,0,0" />
                </StackPanel>

                <!-- TESPİT & FPS -->
                <StackPanel x:Name="FpsPanel" Visibility="Collapsed">
                    <TextBlock Text="🎯 Tespit &amp; FPS Ölçüm" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,16" />

                    <CheckBox x:Name="CbFpsMonitor" Content="PresentMon ile gerçek FPS ölçümü"
                              Style="{StaticResource ToggleSwitchStyle}" Margin="0,6" />
                    <CheckBox x:Name="CbAutoActivate" Content="Oyun başlayınca Turbo'yu otomatik aç"
                              Style="{StaticResource ToggleSwitchStyle}" Margin="0,6" />

                    <TextBlock TextWrapping="Wrap" Margin="0,12,0,0"
                               Foreground="{DynamicResource TextSecondary}" FontSize="11">
                        ⚠ Valorant (Vanguard) oynarken FPS Monitor'u kapatmak isteyebilirsin —
                        PresentMon ETW'yi Vanguard "şüpheli telemetri" olarak işaretleyebilir (ban vermez ama uyarı verir).
                    </TextBlock>
                </StackPanel>

                <!-- GÖRÜNÜM & TEMA -->
                <StackPanel x:Name="ThemePanel" Visibility="Collapsed">
                    <TextBlock Text="🎨 Tema Seçimi" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,16" />

                    <UniformGrid Columns="3" Rows="1">
                        <Border x:Name="ThemeFox" Width="160" Height="120" Margin="6" CornerRadius="10"
                                Background="#1A1A20" BorderBrush="#FF7A29" BorderThickness="2"
                                Cursor="Hand" MouseLeftButtonUp="ThemeFox_Click">
                            <Grid>
                                <Border Background="#FF7A29" Height="6" VerticalAlignment="Top" CornerRadius="10,10,0,0" />
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="🦊" FontSize="32" HorizontalAlignment="Center" />
                                    <TextBlock Text="Fox" Foreground="#FF7A29" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,6,0,0" />
                                    <TextBlock Text="Turuncu, sıcak" Foreground="#909098" FontSize="10"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border x:Name="ThemeCyber" Width="160" Height="120" Margin="6" CornerRadius="10"
                                Background="#101822" BorderBrush="#00D9FF" BorderThickness="2"
                                Cursor="Hand" MouseLeftButtonUp="ThemeCyber_Click">
                            <Grid>
                                <Border Background="#00D9FF" Height="6" VerticalAlignment="Top" CornerRadius="10,10,0,0" />
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="⚡" FontSize="32" HorizontalAlignment="Center" />
                                    <TextBlock Text="Cyber" Foreground="#00D9FF" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,6,0,0" />
                                    <TextBlock Text="Neon mavi" Foreground="#7090A8" FontSize="10"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border x:Name="ThemeRazer" Width="160" Height="120" Margin="6" CornerRadius="10"
                                Background="#141A14" BorderBrush="#44D62C" BorderThickness="2"
                                Cursor="Hand" MouseLeftButtonUp="ThemeRazer_Click">
                            <Grid>
                                <Border Background="#44D62C" Height="6" VerticalAlignment="Top" CornerRadius="10,10,0,0" />
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="🎮" FontSize="32" HorizontalAlignment="Center" />
                                    <TextBlock Text="Razer" Foreground="#44D62C" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,6,0,0" />
                                    <TextBlock Text="Neon yeşil" Foreground="#80A080" FontSize="10"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </UniformGrid>

                    <TextBlock x:Name="ThemeNote" Text="Tema seçildi. Uygulamayı yeniden başlatınca tam uygulanır."
                               Foreground="{DynamicResource AccentBrush}" Margin="0,12,0,0" FontSize="11" />
                </StackPanel>

                <!-- OVERLAY -->
                <StackPanel x:Name="OverlayPanel" Visibility="Collapsed">
                    <TextBlock Text="📺 Oyun-içi Overlay" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4" />
                    <TextBlock Text="Overlay'de hangi metrikler görünsün ve nasıl yerleşsin?"
                               Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="0,0,0,16" />

                    <TextBlock Text="Gösterilecek Metrikler" FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,8" />
                    <CheckBox x:Name="OvFps" Content="🎯 FPS — anlık frame rate"
                              Style="{StaticResource ToggleSwitchStyle}" Margin="0,6" />
                    <CheckBox x:Name="OvCpu" Content="🔥 CPU — sıcaklık + kullanım yüzdesi"
                              Style="{StaticResource ToggleSwitchStyle}" Margin="0,6" />
                    <CheckBox x:Name="OvGpu" Content="🎮 GPU — sıcaklık + kullanım yüzdesi"
                              Style="{StaticResource ToggleSwitchStyle}" Margin="0,6" />
                    <CheckBox x:Name="OvRam" Content="💾 RAM — kullanılan/toplam"
                              Style="{StaticResource ToggleSwitchStyle}" Margin="0,6" />

                    <TextBlock Text="Yerleşim" FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBrush}" Margin="0,20,0,8" />
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="OvHorizontal" Content="↔ Yatay" GroupName="Orient" Margin="0,0,16,0"
                                     Foreground="{DynamicResource TextPrimary}" />
                        <RadioButton x:Name="OvVertical" Content="↕ Dikey" GroupName="Orient" Margin="0,0,16,0"
                                     Foreground="{DynamicResource TextPrimary}" />
                        <RadioButton x:Name="OvSquare" Content="⬜ Kare 2x2" GroupName="Orient"
                                     Foreground="{DynamicResource TextPrimary}" />
                    </StackPanel>

                    <Border Background="{DynamicResource PanelBrushDim}" BorderBrush="{DynamicResource BorderBrushDim}"
                            BorderThickness="1" CornerRadius="8" Padding="14,10" Margin="0,20,0,0">
                        <StackPanel>
                            <TextBlock Text="🔑 Hotkey: Ctrl+Alt+L" Foreground="{DynamicResource AccentBrush}"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Overlay'in kilidini her yerden aç/kapat (oyun içi dahil)"
                                       Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- HOTKEYS -->
                <StackPanel x:Name="HotkeyPanel" Visibility="Collapsed">
                    <TextBlock Text="⌨ Hotkeys" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4" />
                    <TextBlock Text="Her yerden çalışan global tuş kısayolları. Düzenle butonuyla değiştir."
                               Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="0,0,0,16" />

                    <CheckBox x:Name="CbHotkey" Content="Global hotkey'ler aktif"
                              Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,16" />

                    <Border Style="{StaticResource ModernCard}" Padding="14,12" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="🚀 Turbo Toggle" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}" />
                                <TextBlock Text="Turbo modunu aç/kapat — her yerden çalışır"
                                           FontSize="10" Foreground="{DynamicResource TextSecondary}" />
                            </StackPanel>
                            <Border Grid.Column="1" Background="{DynamicResource HighlightPanelChip}"
                                    CornerRadius="6" Padding="10,4" Margin="0,0,8,0">
                                <TextBlock x:Name="HkTurboLabel" Text="Ctrl+Alt+T"
                                           Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" />
                            </Border>
                            <Button Grid.Column="2" Content="Düzenle" Tag="turbo"
                                    Click="EditHotkey_Click" Padding="12,4" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource ModernCard}" Padding="14,12" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="📺 Overlay Toggle" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}" />
                                <TextBlock Text="Oyun-içi overlay aç/kapat"
                                           FontSize="10" Foreground="{DynamicResource TextSecondary}" />
                            </StackPanel>
                            <Border Grid.Column="1" Background="{DynamicResource HighlightPanelChip}"
                                    CornerRadius="6" Padding="10,4" Margin="0,0,8,0">
                                <TextBlock x:Name="HkOverlayLabel" Text="Ctrl+Alt+O"
                                           Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" />
                            </Border>
                            <Button Grid.Column="2" Content="Düzenle" Tag="overlay"
                                    Click="EditHotkey_Click" Padding="12,4" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource ModernCard}" Padding="14,12" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="🔓 Overlay Kilit" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}" />
                                <TextBlock Text="Overlay konumunu kilitle/aç (taşıma için)"
                                           FontSize="10" Foreground="{DynamicResource TextSecondary}" />
                            </StackPanel>
                            <Border Grid.Column="1" Background="{DynamicResource HighlightPanelChip}"
                                    CornerRadius="6" Padding="10,4" Margin="0,0,8,0">
                                <TextBlock x:Name="HkLockLabel" Text="Ctrl+Alt+L"
                                           Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" />
                            </Border>
                            <Button Grid.Column="2" Content="Düzenle" Tag="lock"
                                    Click="EditHotkey_Click" Padding="12,4" />
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- GELİŞMİŞ -->
                <StackPanel x:Name="AdvancedPanel" Visibility="Collapsed">
                    <TextBlock Text="🔧 Gelişmiş" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,16" />

                    <CheckBox x:Name="CbAutoStart" Content="⚡ Windows başlangıcında Fox Turbo Mod'u otomatik aç"
                              Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,16"
                              Checked="AutoStart_Toggle" Unchecked="AutoStart_Toggle" />

                    <Button Content="📁 Settings klasörünü aç (%LOCALAPPDATA%\FoxMod)"
                            Click="OpenSettingsFolder_Click" HorizontalAlignment="Left" Padding="14,6" />
                    <Button Content="📋 Log dosyasını aç" Margin="0,8,0,0"
                            Click="OpenLogFile_Click" HorizontalAlignment="Left" Padding="14,6" />
                    <Button Content="🗑 Geçmişi temizle (history.json)"
                            Click="ClearHistory_Click" Margin="0,8,0,0"
                            HorizontalAlignment="Left" Padding="14,6" />
                    <Button Content="↩ Tüm ayarları varsayılana döndür"
                            Click="ResetSettings_Click" Margin="0,8,0,0"
                            Background="#3A1A1A" BorderBrush="#A03333" Foreground="#FF9988"
                            HorizontalAlignment="Left" Padding="14,6" />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
