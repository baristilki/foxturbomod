<Window x:Class="TurboMode.Views.HotkeyCaptureDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Hotkey Yakala" Height="240" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource WindowBackground}"
        KeyDown="Window_KeyDown" Focusable="True">

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="TitleLabel" Text="🔑 Hotkey: Turbo Toggle"
                   FontSize="14" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,12" />

        <Border Grid.Row="1" Style="{StaticResource ModernCard}" Padding="20"
                VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Yeni kombinasyon için tuş kombinasyonuna bas"
                           Foreground="{DynamicResource TextSecondary}" FontSize="11"
                           HorizontalAlignment="Center" Margin="0,0,0,12" />
                <TextBlock x:Name="ComboLabel" Text="—" FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource AccentBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="İptal" Width="90" Margin="0,0,8,0" Click="Cancel_Click" />
            <Button Content="Kaydet" Width="100" Click="Save_Click"
                    Background="{DynamicResource AccentBrush}" Foreground="White" />
        </StackPanel>
    </Grid>
</Window>
