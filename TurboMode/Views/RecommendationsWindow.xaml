<Window x:Class="TurboMode.Views.RecommendationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Sistem Önerileri" Height="720" Width="640"
        WindowStartupLocation="CenterOwner"
        Background="#0E0E13" Icon="/Resources/FoxMod.ico">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="🚀 FPS Önerileri"
                   FontSize="18" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimary}" />
        <TextBlock Grid.Row="1" Margin="0,4,0,16" TextWrapping="Wrap"
                   Foreground="{StaticResource TextSecondary}" FontSize="12">
            Sistemini analiz ettim. Aşağıdaki öneriler — bazıları otomatik uygulanabilir,
            bazıları manuel rehber gerektiriyor. <Run FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}">Her birinin FPS etkisi belirtildi.</Run>
        </TextBlock>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="RecList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="14,12" CornerRadius="10"
                                Background="{Binding BackgroundBrush}"
                                BorderBrush="{Binding BorderBrush}" BorderThickness="1"
                                Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding Item.IconEmoji}"
                                           FontSize="22" VerticalAlignment="Top"
                                           Margin="0,2,12,0" />

                                <StackPanel Grid.Column="1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Item.Title}"
                                                   FontWeight="SemiBold" FontSize="13"
                                                   Foreground="{StaticResource TextPrimary}" />
                                        <Border Background="{Binding ImpactBrush}"
                                                CornerRadius="6" Padding="6,1" Margin="8,2,0,0"
                                                Visibility="{Binding HasImpact, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="{Binding Item.FpsImpact}" FontSize="10"
                                                       Foreground="White" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Item.Description}"
                                               Foreground="{StaticResource TextSecondary}"
                                               FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"
                                               LineHeight="16" />
                                </StackPanel>

                                <Button Grid.Column="2" Content="{Binding Item.ActionLabel}"
                                        Visibility="{Binding HasAction, Converter={StaticResource BoolToVis}}"
                                        VerticalAlignment="Top" Margin="12,0,0,0"
                                        Padding="10,4" Cursor="Hand"
                                        Background="Transparent"
                                        BorderBrush="{StaticResource AccentBrush}"
                                        Foreground="{StaticResource AccentBrush}"
                                        Click="Action_Click" Tag="{Binding Item}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
