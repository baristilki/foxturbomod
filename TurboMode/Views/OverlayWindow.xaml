<Window x:Class="TurboMode.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fox Overlay"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True"
        Background="Transparent" Topmost="True" ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual" Left="20" Top="20">

    <Border x:Name="OverlayRoot" CornerRadius="12" Padding="14,8">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                <GradientStop Color="#1A000000" Offset="0" />
                <GradientStop Color="#33000000" Offset="0.5" />
                <GradientStop Color="#1A000000" Offset="1" />
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="24" ShadowDepth="0" Opacity="0.5" />
        </Border.Effect>

        <StackPanel x:Name="RootPanel" Orientation="Horizontal">
            <!-- Brand chip -->
            <StackPanel x:Name="BrandBlock" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                <Image Source="/Resources/FoxLogo.png" Width="22" Height="22" Margin="0,0,6,0" />
                <TextBlock Text="FOX" FontSize="13" FontWeight="Bold"
                           Foreground="#FF7A29" VerticalAlignment="Center" />
            </StackPanel>

            <Rectangle x:Name="Sep1" Width="1" Fill="#33FFFFFF" Margin="0,4" />

            <!-- FPS -->
            <Border x:Name="FpsBlock" Padding="12,2,12,2">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🎯" FontSize="16" Margin="0,0,6,0" VerticalAlignment="Center" />
                    <StackPanel>
                        <TextBlock Text="FPS" FontSize="8" Foreground="#888" />
                        <TextBlock x:Name="FpsValue" Text="—" FontSize="18" FontWeight="Bold"
                                   Foreground="#FF7A29" LineHeight="20" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Rectangle x:Name="Sep2" Width="1" Fill="#33FFFFFF" Margin="0,4" />

            <!-- CPU -->
            <Border x:Name="CpuBlock" Padding="12,2,12,2">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🔥" FontSize="16" Margin="0,0,6,0" VerticalAlignment="Center" />
                    <StackPanel>
                        <TextBlock Text="CPU" FontSize="8" Foreground="#888" />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="CpuTempValue" Text="—" FontSize="14" FontWeight="SemiBold"
                                       Foreground="#7FD49F" LineHeight="20" />
                            <TextBlock x:Name="CpuLoadValue" Text="" FontSize="10"
                                       Foreground="#AAAAAA" VerticalAlignment="Bottom" Margin="4,0,0,2" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Rectangle x:Name="Sep3" Width="1" Fill="#33FFFFFF" Margin="0,4" />

            <!-- GPU -->
            <Border x:Name="GpuBlock" Padding="12,2,12,2">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🎮" FontSize="16" Margin="0,0,6,0" VerticalAlignment="Center" />
                    <StackPanel>
                        <TextBlock Text="GPU" FontSize="8" Foreground="#888" />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="GpuTempValue" Text="—" FontSize="14" FontWeight="SemiBold"
                                       Foreground="#7FD49F" LineHeight="20" />
                            <TextBlock x:Name="GpuLoadValue" Text="" FontSize="10"
                                       Foreground="#AAAAAA" VerticalAlignment="Bottom" Margin="4,0,0,2" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Rectangle x:Name="Sep4" Width="1" Fill="#33FFFFFF" Margin="0,4" />

            <!-- RAM -->
            <Border x:Name="RamBlock" Padding="12,2,12,2">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="💾" FontSize="16" Margin="0,0,6,0" VerticalAlignment="Center" />
                    <StackPanel>
                        <TextBlock Text="RAM" FontSize="8" Foreground="#888" />
                        <TextBlock x:Name="RamValue" Text="—" FontSize="14" FontWeight="SemiBold"
                                   Foreground="White" LineHeight="20" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Rectangle x:Name="Sep5" Width="1" Fill="#33FFFFFF" Margin="0,4" />

            <!-- Turbo dot + Lock -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                <Ellipse x:Name="TurboDot" Width="10" Height="10" Margin="0,0,8,0"
                         Fill="#555" VerticalAlignment="Center"
                         ToolTip="Turbo Aktif Göstergesi">
                    <Ellipse.Effect>
                        <DropShadowEffect x:Name="DotGlow" Color="#555" BlurRadius="0" ShadowDepth="0" Opacity="0" />
                    </Ellipse.Effect>
                </Ellipse>
                <TextBlock x:Name="LockIcon" Text="🔓" FontSize="14" Cursor="Hand"
                           Background="#22000000" Padding="6,2" Margin="0,0,4,0"
                           PreviewMouseLeftButtonDown="LockIcon_PreviewDown"
                           MouseLeftButtonUp="ToggleLock_Click"
                           ToolTip="Tıkla: konum kilidini değiştir (Ctrl+Alt+L)"
                           VerticalAlignment="Center" />
                <TextBlock Text="✕" FontSize="14" Cursor="Hand"
                           Background="#33330000" Padding="6,2"
                           PreviewMouseLeftButtonDown="LockIcon_PreviewDown"
                           MouseLeftButtonUp="CloseOverlay_Click"
                           ToolTip="Overlay'i kapat"
                           Foreground="#FF8888"
                           VerticalAlignment="Center" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
