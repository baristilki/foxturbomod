<Window x:Class="TurboMode.Views.DriverScanWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Sürücü Taraması" Height="600" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackground}"
        Icon="/Resources/FoxMod.ico">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="💿 Sürücü Taraması"
                   FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimary}" />
        <TextBlock Grid.Row="1" Margin="0,4,0,12" TextWrapping="Wrap"
                   Foreground="{DynamicResource TextSecondary}" FontSize="11">
            GPU, ses, ağ ve chipset sürücülerini sistemde tarar.
            <Run FontWeight="SemiBold" Foreground="#CC9933">Eski (1+ yıl)</Run> veya
            <Run FontWeight="SemiBold" Foreground="#E04040">Eski (2+ yıl)</Run> işaretli olanları güncellemen önerilir.
        </TextBlock>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="🔄 Yeniden Tara" Click="Rescan_Click"
                    Style="{StaticResource ModernButton}" Padding="12,6" Margin="0,0,8,0" />
            <TextBlock x:Name="StatusLabel" Text="Tarama tamamlandı"
                       Foreground="{DynamicResource TextSecondary}" FontSize="11"
                       VerticalAlignment="Center" />
        </StackPanel>

        <Border Grid.Row="3" Background="{DynamicResource PanelBrushDim}"
                BorderBrush="{DynamicResource BorderBrushDim}" BorderThickness="1"
                CornerRadius="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="DriversList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="14,10" Margin="4" CornerRadius="6"
                                    Background="{DynamicResource PanelBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Category}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimary}"
                                                   FontWeight="SemiBold" FontSize="12"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Foreground="{DynamicResource TextSecondary}" FontSize="10">
                                            <Run Text="v" /><Run Text="{Binding Version, Mode=OneWay}" />
                                            <Run Text=" • " />
                                            <Run Text="{Binding Vendor, Mode=OneWay}" />
                                            <Run Text=" • " />
                                            <Run Text="{Binding Date, StringFormat=dd MMM yyyy, Mode=OneWay, FallbackValue=tarih ?}" />
                                        </TextBlock>
                                    </StackPanel>
                                    <Border Grid.Column="2" Padding="8,3" CornerRadius="4"
                                            HorizontalAlignment="Right" VerticalAlignment="Center"
                                            Background="{Binding HealthBrush}">
                                        <TextBlock Text="{Binding Health}" Foreground="White" FontSize="10" />
                                    </Border>
                                    <Button Grid.Column="3" Content="🌐" ToolTip="Sürücü sayfasını aç"
                                            Click="OpenDriverUrl_Click" Tag="{Binding DownloadUrl}"
                                            Style="{StaticResource ModernButton}" Padding="8,4" Margin="8,0,0,0"
                                            Visibility="{Binding HasUrl, Converter={StaticResource BoolToVis}}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
